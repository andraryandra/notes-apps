{
  "name": "notes-app",
  "version": "1.2.1",
  "description": "Beautiful Electron notes app with folders, tags, and rich editor",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "icons": "bash scripts/generate-icons.sh",
    "build": "npm run icons && vite build && electron-builder",
    "build:linux": "npm run icons && vite build && electron-builder --linux",
    "build:win": "npm run icons && vite build && electron-builder --win",
    "build:mac": "npm run icons && vite build && electron-builder --mac",
    "install:app": "bash scripts/install-appimage.sh",
    "install:desktop": "bash scripts/install-desktop.sh",
    "release:app": "npm run build:linux && npm run install:app",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.notes.app",
    "productName": "Notes",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.png",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "id"
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!**/*.map",
      "!**/*.{ts,tsx}",
      "!**/.DS_Store"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office",
      "executableName": "notes-app",
      "artifactName": "Notes-${version}-Linux.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Notes-${version}-Windows-Setup.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "Notes-${version}-macOS.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "andraryandra",
      "repo": "notes-apps"
    }
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.2",
    "better-sqlite3": "^11.9.1",
    "electron-updater": "^6.6.2",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-color": "^2.11.5",
    "@tiptap/extension-font-family": "^2.11.5",
    "@tiptap/extension-highlight": "^2.11.5",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.11.5",
    "@tiptap/extension-table-cell": "^2.11.5",
    "@tiptap/extension-table-header": "^2.11.5",
    "@tiptap/extension-table-row": "^2.11.5",
    "@tiptap/extension-text-style": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "uuid": "^11.0.5",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "xlsx": "^0.18.5"
  }
}
